---
import { getCollection, render } from "astro:content";
import DocsSidebarZh from "../../../components/DocsSidebarZh.astro";
import Layout from "../../../layouts/Layout.astro";

export const prerender = true;

export async function getStaticPaths() {
    const docs = await getCollection("docsZh");
    return docs.map((entry) => {
        const slug = entry.id.replace(/^docs-zh\//, "");
        return {
            params: { slug: slug === "index" ? undefined : slug },
            props: { entry },
        };
    });
}

const { entry } = Astro.props;
const renderedEntry = await render(entry);
void renderedEntry;
---

<Layout title={entry.data.title} description={entry.data.description}>
    <div class="flex gap-8">
        <aside
            class="hidden md:block w-64 shrink-0 overflow-y-auto sticky top-32 max-h-[calc(100vh-10rem)]"
        >
            <DocsSidebarZh />
        </aside>

        <article class="flex-1 min-w-0 main-content">
            <div class="glass-panel p-6 md:p-10 rounded-3xl mb-8">
                <h1 class="text-4xl md:text-5xl font-display font-bold mb-6 text-white">
                    {entry.data.title}
                </h1>
                {
                    entry.data.description && (
                        <p class="text-xl text-gray-400 mb-10 leading-relaxed border-b border-white/10 pb-10">
                            {entry.data.description}
                        </p>
                    )
                }

                <div
                    class="prose prose-invert prose-lg max-w-none prose-headings:font-display prose-a:text-brand-accent hover:prose-a:text-white"
                >
                    <renderedEntry.Content />
                </div>

                <div
                    class="mt-16 pt-8 border-t border-white/10 flex justify-between items-center text-sm font-mono text-gray-500"
                >
                    <div>
                        System Record: zh/{entry.id.replace(/^docs-zh\//, "")}
                    </div>
                    <a
                        href={`https://github.com/IchimaruGin728/gins-blog/tree/main/src/content/docs-zh/${entry.id.replace(/^docs-zh\//, "")}.md`}
                        target="_blank"
                        class="hover:text-white transition-colors flex items-center gap-2"
                    >
                        <span class="i-heroicons-pencil-square"></span> 编辑此页
                    </a>
                </div>
            </div>
        </article>

        <aside class="hidden xl:block w-48 shrink-0 relative">
            <div class="sticky top-32">
                <h3 class="font-bold text-sm text-gray-400 uppercase tracking-wider mb-4">
                    快捷链接
                </h3>
                <ul class="space-y-3 text-sm text-gray-400">
                    <li>
                        <a
                            href="/zh"
                            class="hover:text-brand-accent transition-colors flex items-center gap-2"
                        >
                            <span class="i-heroicons-arrow-left" />
                            返回主页
                        </a>
                    </li>
                    <li>
                        <a
                            href="/zh/blog"
                            class="hover:text-brand-accent transition-colors"
                        >
                            所有技术文章
                        </a>
                    </li>
                </ul>
            </div>
        </aside>
    </div>
</Layout>
